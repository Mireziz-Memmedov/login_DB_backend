{
  "version": 2,
  "builds": [
    {
      "src": "log/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "log/wsgi.py"
    }
  ],
  "functions": {
    "log/wsgi.py": { 
      "memory": 1024,
      "maxDuration": 10,
      "maxRequestBodySize": "50mb"
    }
  }
}

